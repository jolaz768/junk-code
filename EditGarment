<?php

namespace App\Livewire\Pages\Admin\Garment;

use App\Models\Category;
use App\Models\Color;
use App\Models\Fabric;
use App\Models\FabricColor;
use App\Models\Garment;
use App\Models\GarmentColorFabric;
use App\Models\MeasurementField;
use App\Models\MeasurementTemplate;
use App\Models\MeasurementValue;
use Illuminate\Support\Facades\DB;
use Illuminate\Support\Str;
use Livewire\Attributes\Layout;
use Livewire\Attributes\Computed;
use Livewire\Component;
use Livewire\WithFileUploads;

class EditGarment extends Component
{
    use WithFileUploads;

    #[Layout('components.layouts.admin')]

    public Garment $garment;
    public string $name = '';
    public string $slug = '';
    public string $description = '';
    public ?int $category_id = null;
    public ?int $measurement_template_id = null;
    public ?float $base_price = null;
    public $image;
    public array $fabricColorRows = [];
    public array $values = [];

    public function mount($id)
    {
        $this->garment = Garment::with([
            'garmentColorFabrics.fabricColor.fabric',
            'garmentColorFabrics.fabricColor.color',
            // 'measurementTemplate.measurementFields.measurementValue',
        ])->findOrFail($id);

        $this->name = $this->garment->name;
        $this->slug = $this->garment->slug;
        $this->description = $this->garment->description;
        $this->category_id = $this->garment->category_id;
        $this->measurement_template_id = optional($this->garment->measurementTemplate)->id;
        $this->base_price = $this->garment->base_price;

        $rows = [];

        foreach ($this->garment->garmentColorFabrics as $item) {
            if (! $item->fabricColor?->fabric || ! $item->fabricColor?->color) {
                continue;
            }

            $fabricName = Str::of($item->fabricColor->fabric->name)->title()->__toString();
            $colorName = Str::of($item->fabricColor->color->color_name)->title()->__toString();

            if ($fabricName === '' || $colorName === '') {
                continue;
            }

            if (! isset($rows[$fabricName])) {
                $rows[$fabricName] = [
                    'fabric_name' => $fabricName,
                    'colors' => [],
                ];
            }

            $rows[$fabricName]['colors'][] = $colorName;
        }

        $this->fabricColorRows = collect($rows)
            ->map(fn ($row) => [
                'fabric_name' => $row['fabric_name'],
                'colors' => collect($row['colors'])->unique()->values()->all(),
            ])
            ->values()
            ->all();

        if (empty($this->fabricColorRows)) {
            $this->addFabricColorRow();
        }

        foreach ($this->measurementFields() as $field) {
            $this->values[$field->id] = $field->measurementValue?->value;
        }
    }

    #[Computed()]
    public function categories()
    {
        return Category::query()
            ->select('id', 'cat_name')
            ->get();
    }

    #[Computed()]
    public function fabrics()
    {
        return Fabric::query()
            ->select('id', 'name')
            ->get();
    }

    #[Computed()]
    public function colors()
    {
        return Color::query()
            ->select('id', 'color_name')
            ->get();
    }

    #[Computed()]
    public function measurementTemplates()
    {
        return MeasurementTemplate::query()
            ->select('id', 'name')
            ->get();
    }

    #[Computed()]
    public function measurementFields()
    {
        if (! $this->measurement_template_id) {
            return collect();
        }

        return MeasurementField::query()
            ->where('measurement_template_id', $this->measurement_template_id)
            ->get();
    }

    public function updatedName($value)
    {
        if (! $this->slug || $this->slug === Str::slug($this->name)) {
            $this->slug = $this->generateUniqueSlug($value, $this->garment->id);
        }
    }

    public function addFabricColorRow()
    {
        $this->fabricColorRows[] = [
            'fabric_name' => '',
            'colors' => [''],
        ];
    }

    public function removeFabricColorRow($index)
    {
        unset($this->fabricColorRows[$index]);
        $this->fabricColorRows = array_values($this->fabricColorRows);
    }

    public function addFabricColorInput($rowIndex)
    {
        if (! isset($this->fabricColorRows[$rowIndex])) {
            return;
        }

        $this->fabricColorRows[$rowIndex]['colors'][] = '';
    }

    public function removeFabricColorInput($rowIndex, $colorIndex)
    {
        if (! isset($this->fabricColorRows[$rowIndex]['colors'][$colorIndex])) {
            return;
        }

        unset($this->fabricColorRows[$rowIndex]['colors'][$colorIndex]);
        $this->fabricColorRows[$rowIndex]['colors'] = array_values($this->fabricColorRows[$rowIndex]['colors']);
    }

    public function updatedMeasurementTemplateId($value)
    {
        $this->values = [];

        foreach ($this->measurementFields() as $field) {
            $this->values[$field->id] = $field->measurementValue?->value;
        }
    }

    public function rules()
    {
        return [
            'name' => 'required|string|max:255',
            'slug' => 'required|string|max:255|unique:garments,slug,' . $this->garment->id,
            'description' => 'nullable|string|min:10|max:255',
            'category_id' => 'required|exists:categories,id',
            'measurement_template_id' => 'nullable|exists:measurement_templates,id',
            'fabricColorRows' => 'required|array|min:1',
            'fabricColorRows.*.fabric_name' => 'required|string|max:255',
            'fabricColorRows.*.colors' => 'required|array|min:1',
            'fabricColorRows.*.colors.*' => 'required|string|max:255',
            'values' => 'array',
            'values.*' => 'nullable|numeric',
            'base_price' => 'required|numeric|min:0',
            'image' => 'nullable|image|max:2048',
        ];
    }

    public function messages()
    {
        return [
            'name.required' => 'Garment name is required',
            'name.string' => 'Garment name must be a string',
            'name.max' => 'Garment name must not exceed 255 characters',

            'slug.required' => 'Garment slug is required',
            'slug.string' => 'Garment slug must be a string',
            'slug.max' => 'Garment slug must not exceed 255 characters',
            'slug.unique' => 'Garment slug must be unique',

            'description.string' => 'Garment description must be a string',
            'description.min' => 'Garment description must be at least 10 characters',
            'description.max' => 'Garment description must not exceed 255 characters',

            'category_id.required' => 'Category is required',
            'category_id.exists' => 'Selected category does not exist',

            'measurement_template_id.exists' => 'Selected measurement template does not exist',

            'fabricColorRows.required' => 'Enter at least one fabric/color row',
            'fabricColorRows.array' => 'Fabric/color rows must be valid',
            'fabricColorRows.*.fabric_name.required' => 'Fabric name is required',
            'fabricColorRows.*.fabric_name.max' => 'Fabric name cannot exceed 255 characters',
            'fabricColorRows.*.colors.required' => 'At least one color is required for each fabric',
            'fabricColorRows.*.colors.array' => 'Fabric colors must be a list',
            'fabricColorRows.*.colors.*.required' => 'Each color is required',
            'fabricColorRows.*.colors.*.max' => 'Color name cannot exceed 255 characters',

            'values.*.numeric' => 'Measurement values must be numeric',

            'base_price.required' => 'Base price is required',
            'base_price.numeric' => 'Base price must be numeric',
            'base_price.min' => 'Base price must be at least 0',

            'image.image' => 'Image must be an image',
            'image.max' => 'Image must not exceed 2048 kilobytes',
        ];
    }

    public function save()
    {
        $this->validate();

        $this->name = Str::of($this->name)->trim()->title();
        $this->slug = $this->generateUniqueSlug($this->name, $this->garment->id);
        $this->description = trim($this->description);
        $this->base_price = floatval($this->base_price);

        $fabricColorRows = collect($this->fabricColorRows)
            ->map(fn ($row) => [
                'fabric_name' => Str::of($row['fabric_name'] ?? '')->trim()->title(),
                'colors' => collect($row['colors'] ?? [])->map(fn ($color) => Str::of($color)->trim()->title())->filter()->unique()->values()->all(),
            ])
            ->filter(fn ($row) => $row['fabric_name'] !== '' && count($row['colors']) > 0)
            ->values();

        if ($fabricColorRows->isEmpty()) {
            $this->addError('fabricColorRows', 'Enter at least one fabric/color row.');
            return;
        }

        $fabricColorIds = $fabricColorRows->flatMap(function ($row) {
            $fabric = Fabric::firstOrCreate(['name' => $row['fabric_name']]);

            return collect($row['colors'])->map(function ($colorName) use ($fabric) {
                $color = Color::firstOrCreate(['color_name' => $colorName]);

                return FabricColor::firstOrCreate([
                    'fabric_id' => $fabric->id,
                    'color_id' => $color->id,
                ])->id;
            });
        })->unique()->values();

        DB::transaction(function () use ($fabricColorIds) {
            $imagePath = $this->image ? $this->image->store('garments', 'public') : $this->garment->image;

            $this->garment->update([
                'name' => $this->name,
                'slug' => $this->slug,
                'description' => $this->description,
                'category_id' => $this->category_id,
                'base_price' => $this->base_price,
                'image' => $imagePath,
            ]);

            $originalTemplate = $this->garment->measurementTemplate;

            if ($originalTemplate && $originalTemplate->id !== $this->measurement_template_id) {
                $originalTemplate->update(['garment_id' => null]);
            }

            if ($this->measurement_template_id) {
                $template = MeasurementTemplate::query()
                    ->whereKey($this->measurement_template_id)
                    ->first();

                if ($template) {
                    $template->update(['garment_id' => $this->garment->id]);
                }
            }

            $this->garment->garmentColorFabrics()->delete();

            foreach ($fabricColorIds as $fabricColorId) {
                GarmentColorFabric::create([
                    'garment_id' => $this->garment->id,
                    'fabric_color_id' => $fabricColorId,
                ]);
            }

            foreach ($this->measurementFields() as $field) {
                if (! array_key_exists($field->id, $this->values)) {
                    continue;
                }

                $value = $this->values[$field->id];

                if ($value === null || $value === '') {
                    continue;
                }

                MeasurementValue::updateOrCreate([
                    'measurement_field_id' => $field->id,
                ], [
                    'value' => floatval($value),
                ]);
            }
        });

        session()->flash('success', 'Garment updated successfully!');

        return redirect()->route('admin.garment.view');
    }

    protected function generateUniqueSlug(string $name, ?int $exceptId = null): string
    {
        $slug = Str::slug($name);
        $original = $slug;
        $count = 1;

        while (Garment::query()
            ->when($exceptId, fn ($query) => $query->where('id', '!=', $exceptId))
            ->where('slug', $slug)
            ->exists()) {
            $slug = $original . '-' . $count++;
        }

        return $slug;
    }

    public function render()
    {
        return view('livewire.pages.admin.garment.edit-garment');
    }
}


